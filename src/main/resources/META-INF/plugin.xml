<!-- Plugin Configuration File: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- Unique identifier of the plugin. It should be FQN, cannot be changed between the plugin versions. -->
    <id>com.aesir-interactive.Angelscript</id>

    <!-- Public plugin name should be written in Title Case.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-name -->
    <name>AngelScript</name>

    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <vendor url="https://aesir-interactive.com">Aesir Interactive</vendor>

    <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-description -->
    <description>AngelScript support for Rider (Debugging, Language Server, Syntax Highlighting)</description>

    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.lsp</depends>

    <depends>com.intellij.modules.json</depends>
    <depends>com.intellij.modules.platform</depends>
<!--    <depends>com.intellij.properties</depends>-->
    <resource-bundle>messages.MyMessageBundle</resource-bundle>
    <!-- Extensions defined by the plugin.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij">
<!--        <toolWindow id="MyToolWindow" factoryClass="com.aesirinteractive.angelscript.MyToolWindowFactory"-->
<!--                    icon="AllIcons.Toolwindows.ToolWindowPalette"/>-->
        <applicationService serviceImplementation="com.aesirinteractive.angelscript.AngelscriptSettings"/>
        <applicationConfigurable
            parentId="tools"
            instance="com.aesirinteractive.angelscript.AngelscriptSettingsConfigurable"
            id="com.aesirinteractive.angelscript.settings"
            displayName="AngelScript"/>
        <platform.lsp.serverSupportProvider implementation="com.aesirinteractive.angelscript.AngelscriptLspServerSupportProvider"/>
        <notificationGroup id="AngelScript LSP" displayType="BALLOON"/>
        <fileType
            name="AngelScript"
            implementationClass="com.aesirinteractive.angelscript.AngelscriptFileType"
            fieldName="INSTANCE"
            language="AngelScript"
            extensions="as" />
        <configurationType implementation="com.aesirinteractive.angelscript.AngelscriptConfigurationType"/>
        <programRunner implementation="com.aesirinteractive.angelscript.AngelscriptProgramRunner"/>
        <xdebugger.breakpointType implementation="com.aesirinteractive.angelscript.AngelscriptBreakpointType"/>
        <postStartupActivity implementation="com.aesirinteractive.angelscript.AngelscriptProjectSetupActivity"/>
        <projectService serviceImplementation="com.aesirinteractive.angelscript.AngelscriptInlineValuesService" id="ANGELSCRIPT_INLINE_VALUES"/>
        <editor.linePainter implementation="com.aesirinteractive.angelscript.AngelscriptEditorLinePainter"/>

        <lang.parserDefinition
                language="AngelScript"
                implementationClass="com.aesirinteractive.angelscript.AngelscriptParserDefinition"/>
        <lang.syntaxHighlighterFactory
                language="AngelScript"
                implementationClass="com.aesirinteractive.angelscript.AngelscriptSyntaxHighlighterFactory"/>

        <colorSettingsPage
                implementation="com.aesirinteractive.angelscript.AngelscriptColorSettingsPage"/>

        <annotator
                language="AngelScript"
                implementationClass="com.aesirinteractive.angelscript.AngelscriptAnnotator"/>

        <lang.psiStructureViewFactory
                language="AngelScript"
                implementationClass="com.aesirinteractive.angelscript.AngelscriptStructureViewFactory"/>

        <externalFormatProcessor
                id="ANGELSCRIPT_CLANGD_FORMATTER"
                implementation="com.aesirinteractive.angelscript.AngelscriptExternalFormatter"/>
    </extensions>
</idea-plugin>
